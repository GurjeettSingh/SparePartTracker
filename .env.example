# Backend
DATABASE_URL=postgresql+pg8000://spareparts:spareparts@db:5432/spareparts
CORS_ORIGINS=http://localhost:3001
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_DAYS=7
JWT_ALGORITHM=HS256

# Frontend
# Preferred (used by the frontend)
NEXT_PUBLIC_API_URL=http://localhost:8001

# Back-compat (older name; still supported)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Default admin user (seeded when the users table is empty)
# Change these before first run if you don't want the defaults.
DEFAULT_ADMIN_MOBILE=9999999999
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_FIRST_NAME=Admin
DEFAULT_ADMIN_LAST_NAME=User
DEFAULT_ADMIN_WORKSHOP_NAME=Default Workshop
DEFAULT_ADMIN_EMAIL=admin@example.com
